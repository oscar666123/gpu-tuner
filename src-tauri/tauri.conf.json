{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GPU Tuner",
  "version": "0.1.4",
  "identifier": "com.gputuner.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GPU Tuner",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "oscar666123",
    "homepage": "https://github.com/oscar666123/gpu-tuner",
    "icon": ["icons/icon.ico"],
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installerHooks": "nsis/desktop-shortcut-options.nsh"
      }
    }
  }
}
